{
  "compilerOptions": {
    /* Target & Module System */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    
    /* File Layout */
    // "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,

    /* Basic Support */
    "lib": ["ESNext"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Strictness */
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,

    /* Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Prisma & Bundler compatibility */
    "resolveJsonModule": true
  },
  "include": [
    "server.ts",
    "prisma.config.ts",
    "check_lessons.ts",
    "check_plans.ts",
    "routes/**/*",
    "middleware/**/*",
    "services/**/*",
    "types/**/*",
    "lib/**/*",
    "constants/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}