{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/v1/:path*",
        "destination": "https://backend.anhoc.com/api/v1/:path*",
        "regex": "^/api/v1(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/users/[userId]",
      "regex": "^/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/admin/users/(?<nxtPuserId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/admin/users/[userId]/attempts/[attemptId]",
      "regex": "^/admin/users/([^/]+?)/attempts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId",
        "nxtPattemptId": "nxtPattemptId"
      },
      "namedRegex": "^/admin/users/(?<nxtPuserId>[^/]+?)/attempts/(?<nxtPattemptId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/student/games/challenge/[code]",
      "regex": "^/student/games/challenge/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcode": "nxtPcode"
      },
      "namedRegex": "^/student/games/challenge/(?<nxtPcode>[^/]+?)(?:/)?$"
    },
    {
      "page": "/student/learning/[gradeId]",
      "regex": "^/student/learning/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgradeId": "nxtPgradeId"
      },
      "namedRegex": "^/student/learning/(?<nxtPgradeId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/student/learning/[gradeId]/[lessonId]",
      "regex": "^/student/learning/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgradeId": "nxtPgradeId",
        "nxtPlessonId": "nxtPlessonId"
      },
      "namedRegex": "^/student/learning/(?<nxtPgradeId>[^/]+?)/(?<nxtPlessonId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/student/practice/[attemptId]",
      "regex": "^/student/practice/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPattemptId": "nxtPattemptId"
      },
      "namedRegex": "^/student/practice/(?<nxtPattemptId>[^/]+?)(?:/)?$"
    }
  ],
